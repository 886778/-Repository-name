{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.ai-bazi.invalid/m4/four-pillars-result/1.0.0",
  "title": "M4 Four Pillars Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "ruleManifestId",
    "authority",
    "pillars",
    "evidence",
    "outputs"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "ruleManifestId": { "type": "string", "minLength": 1 },
    "authority": { "enum": ["expert_approved", "engineering_fixture"] },
    "pillars": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        { "$ref": "#/$defs/yearPillar" },
        { "$ref": "#/$defs/monthPillar" },
        { "$ref": "#/$defs/dayPillar" },
        { "$ref": "#/$defs/hourPillar" }
      ],
      "items": false
    },
    "evidence": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "outputs": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["outputId", "value", "evidenceIds"],
        "properties": {
          "outputId": {
            "type": "string",
            "pattern": "^four_pillars\\.(year|month|day|hour)$"
          },
          "value": { "type": ["string", "integer", "boolean"] },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "$defs": {
    "stem": {
      "enum": [
        "jia",
        "yi",
        "bing",
        "ding",
        "wu",
        "ji",
        "geng",
        "xin",
        "ren",
        "gui"
      ]
    },
    "branch": {
      "enum": [
        "zi",
        "chou",
        "yin",
        "mao",
        "chen",
        "si",
        "wu",
        "wei",
        "shen",
        "you",
        "xu",
        "hai"
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "ruleSetId",
        "ruleSetVersion",
        "algorithmId",
        "algorithmVersion",
        "adrReferences"
      ],
      "properties": {
        "ruleId": { "type": "string", "minLength": 1 },
        "ruleSetId": { "type": "string", "minLength": 1 },
        "ruleSetVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "algorithmId": { "type": "string", "minLength": 1 },
        "algorithmVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "adrReferences": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "pillar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "stem", "branch", "rule", "evidenceIds"],
      "properties": {
        "kind": { "enum": ["year", "month", "day", "hour"] },
        "stem": { "$ref": "#/$defs/stem" },
        "branch": { "$ref": "#/$defs/branch" },
        "rule": { "$ref": "#/$defs/rule" },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "yearPillar": {
      "allOf": [
        { "$ref": "#/$defs/pillar" },
        { "properties": { "kind": { "const": "year" } } }
      ]
    },
    "monthPillar": {
      "allOf": [
        { "$ref": "#/$defs/pillar" },
        { "properties": { "kind": { "const": "month" } } }
      ]
    },
    "dayPillar": {
      "allOf": [
        { "$ref": "#/$defs/pillar" },
        { "properties": { "kind": { "const": "day" } } }
      ]
    },
    "hourPillar": {
      "allOf": [
        { "$ref": "#/$defs/pillar" },
        { "properties": { "kind": { "const": "hour" } } }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "version", "kind"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceId",
        "kind",
        "name",
        "value",
        "ruleId",
        "ruleSetId",
        "ruleSetVersion",
        "algorithmId",
        "algorithmVersion",
        "calculatedAt",
        "parentIds",
        "sources"
      ],
      "properties": {
        "evidenceId": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["input_snapshot", "intermediate_value", "output_value"]
        },
        "name": { "type": "string", "minLength": 1 },
        "value": { "type": ["string", "integer", "boolean"] },
        "ruleId": { "type": ["string", "null"] },
        "ruleSetId": { "type": "string", "minLength": 1 },
        "ruleSetVersion": { "type": "string" },
        "algorithmId": { "type": "string", "minLength": 1 },
        "algorithmVersion": { "type": "string" },
        "calculatedAt": { "type": "string", "format": "date-time" },
        "parentIds": { "type": "array", "items": { "type": "string" } },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      }
    }
  }
}
